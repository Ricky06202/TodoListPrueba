@page "/"

<PageTitle>Todo Master - Inicio</PageTitle>

<div class="home-container">
    <!-- Hero Icon -->
    <div class="hero-icon-container">
        <svg class="hero-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
    </div>

    <!-- Title & Subtitle -->
    <h1 class="title">
        Todo <span class="title-highlight">Master</span>
    </h1>
    
    <p class="subtitle">
        Gestiona tus tareas con elegancia y simplicidad. La herramienta definitiva para organizar tu flujo de trabajo
        diario.
    </p>

    <!-- Call to Action -->
    <a href="todo" class="cta-button">
        Empezar Ahora
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"
             style="width: 1.25rem; height: 1.25rem; margin-left: 0.5rem; color: #fff;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
    </a>

    <!-- Features -->
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-title">Puro CSS</div>
            <p class="feature-desc">Optimizado al máximo sin frameworks externos.</p>
        </div>
        <div class="feature-card">
            <div class="feature-title">Elegante</div>
            <p class="feature-desc">Diseño minimalista con Scoped CSS.</p>
        </div>
        <div class="feature-card">
            <div class="feature-title">Robusto</div>
            <p class="feature-desc">Basado en la potencia de .NET 10.</p>
        </div>
    </div>
</div>
