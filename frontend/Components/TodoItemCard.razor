@using frontend.Models

<div class="todo-card">
    <div class="todo-info" @onclick="() => ToggleCompleted(!Todo.Completed)">
        <div class="checkbox @(Todo.Completed ? "completed" : "")">
            @if (Todo.Completed)
            {
                <svg class="check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
            }
        </div>
        <span class="todo-title @(Todo.Completed ? "completed" : "")">
            @Todo.Title
        </span>
    </div>

    <button @onclick="DeleteTask" @onclick:stopPropagation class="delete-button" title="Eliminar">
        <svg class="delete-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
    </button>
</div>

@code {
    [Parameter] public TodoItem Todo { get; set; } = new();
    [Parameter] public EventCallback<TodoItem> OnToggle { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private async Task ToggleCompleted(bool value)
    {
        Todo.Completed = value;
        await OnToggle.InvokeAsync(Todo);
    }

    private async Task DeleteTask()
    {
        if (Todo.Id.HasValue)
        {
            await OnDelete.InvokeAsync(Todo.Id.Value);
        }
    }
}
